{
  "log": {
    "disabled": false,
    "level": "error",
    "timestamp": true
  },
  "dns": {
    "rules": [
      {
        "clash_mode": "Direct",
        "action": "route",
        "server": "direct"
      },
      {
        "clash_mode": "Global",    
        "action": "route",
        "server": "proxy"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "rule_set": "geosite-ru"
          }
          {
            "domain_suffix": [
              "licard.com",
              "tricolor.tv",
              "wishmaster.me",
              "wylsa.com",
              "quantum-a.io"
            ]
          }
        ],
        "action": "route",
        "server": "russian"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "rule_set": "geosite-apple"
          },
          {
            "domain_suffix": [
              "cdntogo.net",
              "vfsglobal.com",
              "mirror.gcr.io",
              "duolingo.com",
              "my.microsoftpersonalcontent.com",
              "izi.me",
              "iziyo.xyz"
            ]
          }
        ],
        "action": "route",
        "server": "direct"
      }
    ],
    "final": "proxy",
    "strategy": "ipv4_only",
    "reverse_mapping": true,
    "disable_cache": false,
    "disable_expire": false,
    "independent_cache": true
  },
  "inbounds": [
  ],
  "outbounds": [
    {
      "type": "direct",
      "tag": "direct"
    }
  ],
  "route": {
    "default_domain_resolver": {
      "server": "proxy"
    },
    "rule_set": [
      {
        "type": "remote",
        "tag": "geosite-apple",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-apple.srs",
        "download_detour": "proxy"
      },
      {
        "type": "remote",
        "tag": "geosite-ru",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geosite/rule-set/geosite-category-ru.srs",
        "download_detour": "proxy"
      },
      {
        "type": "remote",
        "tag": "geoip-ru",
        "format": "binary",
        "url": "https://raw.githubusercontent.com/SagerNet/sing-geoip/rule-set/geoip-ru.srs",
        "download_detour": "proxy"
      }
    ],
    "rules": [
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "protocol": "dns"
          },
          {
            "port": 53
          }
        ],
        "action": "hijack-dns"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "port": 853
          },
          {
            "network": "udp",
            "port": 443
          }
        ],
        "action": "reject"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      },
      {
        "clash_mode": "Direct",
        "outbound": "direct"
      },
      {
        "clash_mode": "Global",
        "outbound": "proxy"
      },
      {
        "domain_suffix": [
          "exler.ru",
          "habr.ru",
          "habr.com",
          "apple-relay.apple.com"
        ],
        "outbound": "proxy"
      },
      {
        "type": "logical",
        "mode": "or",
        "rules": [
          {
            "rule_set": "geosite-ru"
          },
          {
            "rule_set": "geoip-ru"
          },
          {
            "domain_suffix": [
              "cdntogo.net",
              "licard.com",
              "tricolor.tv",
              "wishmaster.me",
              "wylsa.com",
              "quantum-a.io",
              "vfsglobal.com",
              "mirror.gcr.io",
              "duolingo.com",
              "my.microsoftpersonalcontent.com",
              "izi.me",
              "iziyo.xyz"
            ]
          }
        ],
        "outbound": "direct"
      },
      {
        "protocol": "quic",
        "action": "reject"
      }
    ],
    "final": "proxy",
    "auto_detect_interface": true
  },
  "experimental": {
    "cache_file": {
      "enabled": true
    }
  }
}
